# Copy this file to `.env` and change the values.
# --- Auth0 (gates every route except /health) ---
# The backend verifies the Auth0 access token the browser sends. These must match
# the frontend's VITE_AUTH0_DOMAIN / VITE_AUTH0_AUDIENCE.
# Domain: Auth0 dashboard → Applications → your app → Settings → Domain.
AUTH0_DOMAIN=dev-xxxxxx.us.auth0.com
# Audience: the Identifier of your Auth0 API (Applications → APIs).
AUTH0_AUDIENCE=https://matchview-api

# Port the local server listens on. 8787 matches wrangler's default so the
# frontend's API base URL stays the same if we ever move pieces around.
PORT=8787

# --- Cloudflare R2 (S3-compatible object storage) ---
# All four come from the Cloudflare dashboard (R2 → your bucket → API tokens).
# Account ID is in the R2 overview page URL / sidebar.
R2_ACCOUNT_ID=your-account-id
# Access key + secret are shown ONCE when you create an R2 API token. Save them.
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
# The bucket you created, e.g. matchview-media-dev.
R2_BUCKET=matchview-media-dev

# Upload chunk size in bytes. 100 MB. Must be >= 5 MB (an S3/R2 rule).
PART_SIZE=104857600
