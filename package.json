{
  "name": "matchview-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "MatchView demo coordinator — hands out R2 upload URLs, kicks off AI jobs, relays results.",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "tsx --env-file=.env src/server.ts",
    "start:docker": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx --env-file=.env scripts/smoke-upload.ts",
    "smoke:projects": "tsx --env-file=.env scripts/smoke-projects.ts",
    "smoke:media": "tsx --env-file=.env scripts/smoke-media.ts",
    "smoke:http": "tsx --env-file=.env scripts/smoke-http.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
